body{
    background:#050505;
    color:#00ffff;
    font-family:Arial, sans-serif;
    margin:0;
    padding:20px;
}

.container{
    max-width:1200px;
    margin:auto;
}

h1{
    text-align:center;
}

button{
    padding:12px 25px;
    font-size:18px;
    cursor:pointer;
}

.info{
    margin-top:20px;
}

#hexViewer{
    margin-top:20px;
    border:1px solid #00ffff;
    padding:10px;
    height:600px;
    overflow:auto;
    white-space:pre;
    font-family:Consolas, monospace;
}
